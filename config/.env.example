# NYC DOT Socrata Toolkit — local / analyst deployment
# Copy to project root as .env (or run: python -m socrata_toolkit.install_wizard)

# --- Socrata (required for API rate limits) ---
# Register at https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=data.cityofnewyork.us

# --- Optional PostgreSQL (PostGIS conflicts, warehouse sources) ---
# Local Docker default:
# PG_DSN=postgresql://dot_user:dot_pass@localhost:5432/sidewalk_db
PG_DSN=

# --- Local paths ---
DATA_DIR=./data
OUTPUT_DIR=./outputs
ANALYST_PROFILE=./config/analyst_profile.yaml
DUCKDB_PATH=./nyc_mission_control.duckdb

# --- Docker Compose (postgres service) ---
POSTGRES_USER=dot_user
POSTGRES_PASSWORD=dot_pass
POSTGRES_DB=sidewalk_db

# --- Analyst scheduled runner (profile: analyst) ---
ANALYST_CRON=0 6 * * 1

# --- Non-interactive wizard (docker compose run setup) ---
# WIZARD_NONINTERACTIVE=1
# WIZARD_ALLOW_EMPTY_TOKEN=1
