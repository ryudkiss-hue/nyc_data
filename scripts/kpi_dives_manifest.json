{
  "batch_name": "NYC DOT KPI Analytics Dives",
  "description": "18 comprehensive KPI Dives with statistics, diversity metrics, and risk assessment",
  "version": "1.0.0",
  "created_date": "2026-06-11",
  "dives": [
    {
      "kpi_id": "phase_b_clustering_strength",
      "title": "Phase B: Clustering Strength (Moran's I)",
      "description": "Spatial autocorrelation index quantifying geographic clustering of violations. Includes borough-level statistics, quartile analysis, Simpson's Diversity Index for distribution evenness, and risk thresholds.",
      "phase": "B",
      "unit": "0-1 (autocorrelation index)",
      "benchmark": 0.5,
      "risk_threshold": 0.3,
      "features": [
        "Mean/Median/Min-Max statistics by borough",
        "Quartiles (Q1, IQR, Q3) and standard deviation",
        "Simpson's Diversity Index (distribution evenness)",
        "Cross-tab comparison across all 5 boroughs",
        "Risk status indicators (On Target / At Risk / Critical)",
        "Time-series trend of recent values",
        "Interactive borough selection"
      ],
      "tags": ["phase-b", "spatial", "clustering", "kpi", "analytics"],
      "metric_type": "clustering_score"
    },
    {
      "kpi_id": "phase_b_confidence",
      "title": "Phase B: Clustering Confidence (p-value)",
      "description": "Statistical significance of spatial clustering patterns. Bootstrap-derived confidence with comprehensive distributional analysis and diversity metrics.",
      "phase": "B",
      "unit": "0-1 (p-value)",
      "benchmark": 0.05,
      "risk_threshold": 0.1,
      "features": [
        "Descriptive statistics (mean, median, quartiles, IQR, SD)",
        "Bootstrap confidence intervals",
        "Simpson's Diversity Index for distribution",
        "Cross-borough comparison matrix",
        "Risk escalation indicators",
        "Trend visualization with reference lines",
        "Detailed metadata and methodology"
      ],
      "tags": ["phase-b", "spatial", "significance", "kpi"],
      "metric_type": "confidence"
    },
    {
      "kpi_id": "phase_b_resource_gap",
      "title": "Phase B: Resource Gap Index",
      "description": "Deviation between inspection frequency and violation density by borough. Identifies under-resourced areas with statistical rigor and diversity analysis.",
      "phase": "B",
      "unit": "% (deviation)",
      "benchmark": 20,
      "risk_threshold": 40,
      "features": [
        "Borough-level mean and median resource gaps",
        "Quartile analysis and IQR ranges",
        "Standard deviation and distribution shape",
        "Simpson's Diversity of resource allocation",
        "Cross-tab by borough and resource type",
        "Risk heatmap by borough",
        "Actionable resource reallocation recommendations"
      ],
      "tags": ["phase-b", "resources", "allocation", "kpi"],
      "metric_type": "index"
    },
    {
      "kpi_id": "phase_c_concentration_index",
      "title": "Phase C: Concentration Index (Gini-like)",
      "description": "Percentage of violations concentrated in top 20% of locations. Measures inequality in violation distribution with rich statistical breakdowns.",
      "phase": "C",
      "unit": "% (Gini-equivalent)",
      "benchmark": 50,
      "risk_threshold": 70,
      "features": [
        "Mean concentration by borough (percentage)",
        "Median concentration and quartile breakdown",
        "Min/max concentration extremes",
        "Standard deviation (concentration variability)",
        "Simpson's Diversity Index (equality of distribution)",
        "Cross-tab: borough vs. scope vs. concentration",
        "Risk escalation curve",
        "Historical trend line"
      ],
      "tags": ["phase-c", "distribution", "concentration", "kpi"],
      "metric_type": "percentage"
    },
    {
      "kpi_id": "phase_c_segmentation_potential",
      "title": "Phase C: Segmentation Potential Score",
      "description": "Ability to cleanly separate violations by work scope (ada, sidewalk, ramp). Measures clustering quality of scope categories.",
      "phase": "C",
      "unit": "0-100 (potential score)",
      "benchmark": 70,
      "risk_threshold": 50,
      "features": [
        "Borough-level segmentation potential (mean, median)",
        "Quartile analysis and spread metrics",
        "Standard deviation and distribution shape",
        "Simpson's Diversity of scope distribution",
        "Cross-tab: borough vs. scope feasibility",
        "Clustering quality metrics",
        "Scope-specific analysis tables",
        "Segmentation recommendations"
      ],
      "tags": ["phase-c", "segmentation", "scope", "kpi"],
      "metric_type": "potential_score"
    },
    {
      "kpi_id": "phase_c_type_certainty",
      "title": "Phase C: Type Certainty (Entropy-based)",
      "description": "Confidence in violation classification using entropy measures. Quantifies uncertainty in scope assignment across boroughs.",
      "phase": "C",
      "unit": "0-1 (certainty)",
      "benchmark": 0.85,
      "risk_threshold": 0.7,
      "features": [
        "Mean/median certainty by borough",
        "Quartile distribution (Q1-Q3 with IQR)",
        "Min/max certainty extremes",
        "Standard deviation (certainty variability)",
        "Simpson's Diversity of confidence levels",
        "Entropy-based metrics table",
        "Cross-borough comparison heatmap",
        "Classification quality indicators"
      ],
      "tags": ["phase-c", "classification", "certainty", "kpi"],
      "metric_type": "confidence"
    },
    {
      "kpi_id": "phase_c_distribution_balance",
      "title": "Phase C: Distribution Balance (Shannon Index)",
      "description": "Evenness of violation distribution across boroughs and scopes. Shannon entropy-based measurement of distribution diversity.",
      "phase": "C",
      "unit": "0-1 (Shannon evenness)",
      "benchmark": 0.75,
      "risk_threshold": 0.5,
      "features": [
        "Shannon entropy (0-1 evenness score)",
        "Borough-level distribution statistics",
        "Quartile-based evenness breakdown",
        "IQR and standard deviation metrics",
        "Simpson's Diversity Index (species richness analogy)",
        "Scope-level distribution analysis",
        "Cross-borough and cross-scope tables",
        "Distribution imbalance alerts"
      ],
      "tags": ["phase-c", "diversity", "distribution", "shannon", "kpi"],
      "metric_type": "diversity"
    },
    {
      "kpi_id": "phase_d_outlier_concentration",
      "title": "Phase D: Outlier Concentration (z > 2.0)",
      "description": "Count of statistically significant anomalies identified via z-score analysis. Measures geographic and temporal hotspots.",
      "phase": "D",
      "unit": "count (locations)",
      "benchmark": 20,
      "risk_threshold": 40,
      "features": [
        "Mean outliers per borough",
        "Median outlier count and quartile ranges",
        "Min/max outlier extremes by borough",
        "Standard deviation (outlier variability)",
        "Simpson's Diversity of outlier distribution",
        "Cross-tab: borough vs. severity level",
        "Temporal trend of anomalies",
        "Hotspot map by borough",
        "Risk escalation scoring"
      ],
      "tags": ["phase-d", "anomaly", "outliers", "zscores", "kpi"],
      "metric_type": "count"
    },
    {
      "kpi_id": "phase_d_adoption_rate",
      "title": "Phase D: Risk Adoption Rate",
      "description": "Percentage of high-risk locations where recommended remediation has been implemented. Measures stakeholder response.",
      "phase": "D",
      "unit": "% (adoption rate)",
      "benchmark": 60,
      "risk_threshold": 30,
      "features": [
        "Borough-level adoption rates (mean, median)",
        "Quartile analysis and spread (IQR)",
        "Min/max adoption extremes",
        "Standard deviation (adoption variability)",
        "Simpson's Diversity of adoption patterns",
        "Cross-borough comparison matrix",
        "Adoption timeline (recent 90 days)",
        "Barrier analysis (why non-adoption)",
        "Engagement recommendations"
      ],
      "tags": ["phase-d", "adoption", "engagement", "kpi"],
      "metric_type": "percentage"
    },
    {
      "kpi_id": "phase_d_priority_score",
      "title": "Phase D: Priority Weighting (1-10 scale)",
      "description": "Average priority score across identified anomalies. Composite risk indicator combining severity, urgency, and resource requirements.",
      "phase": "D",
      "unit": "1-10 (priority score)",
      "benchmark": 7,
      "risk_threshold": 5,
      "features": [
        "Mean priority score by borough",
        "Median and quartile distribution",
        "IQR and spread analysis",
        "Standard deviation (priority variability)",
        "Simpson's Diversity of priority levels",
        "Cross-tab: borough vs. priority tier",
        "Priority distribution histogram",
        "High-priority location count",
        "Prioritization recommendations"
      ],
      "tags": ["phase-d", "priority", "severity", "kpi"],
      "metric_type": "score"
    },
    {
      "kpi_id": "phase_e_trend_direction",
      "title": "Phase E: Trend Direction (linear slope)",
      "description": "Linear trend slope in violations over past 90 days. Positive = worsening, negative = improving trend.",
      "phase": "E",
      "unit": "violations/day",
      "benchmark": -0.5,
      "risk_threshold": 0.5,
      "features": [
        "Mean trend slope by borough",
        "Median trend and quartile ranges",
        "Min/max trend extremes",
        "Standard deviation (trend variability)",
        "Simpson's Diversity of trend directions",
        "Cross-borough trend comparison",
        "90-day time-series with regression line",
        "Trend acceleration/deceleration",
        "Forecast impact on SLA targets"
      ],
      "tags": ["phase-e", "trend", "timeseries", "forecast", "kpi"],
      "metric_type": "trend"
    },
    {
      "kpi_id": "phase_e_seasonality_strength",
      "title": "Phase E: Seasonality Index",
      "description": "Strength of seasonal pattern in inspection and violation cycles. Quantifies predictable cyclical behavior.",
      "phase": "E",
      "unit": "0-1 (seasonality strength)",
      "benchmark": 0.4,
      "risk_threshold": 0.7,
      "features": [
        "Mean seasonality by borough",
        "Median seasonal strength and quartiles",
        "Seasonal amplitude (min/max)",
        "Standard deviation of seasonal patterns",
        "Simpson's Diversity of seasonal phases",
        "Cross-borough seasonality matrix",
        "Seasonal decomposition chart",
        "Peak/trough identification",
        "Resource planning implications"
      ],
      "tags": ["phase-e", "seasonality", "cycles", "timeseries", "kpi"],
      "metric_type": "index"
    },
    {
      "kpi_id": "phase_e_resource_gap",
      "title": "Phase E: Resource Demand Forecast Gap",
      "description": "Forecast comparison: inspection capacity needed vs. current allocation. % over/under requirement projection.",
      "phase": "E",
      "unit": "% (over/under gap)",
      "benchmark": 0,
      "risk_threshold": 30,
      "features": [
        "Mean resource gap by borough",
        "Median gap and quartile distribution",
        "Min/max gap extremes",
        "Standard deviation (gap variability)",
        "Simpson's Diversity of resource needs",
        "Cross-borough capacity matrix",
        "Gap trend (narrowing/widening)",
        "Staffing requirement projections",
        "Budget impact estimates"
      ],
      "tags": ["phase-e", "resources", "forecast", "budget", "kpi"],
      "metric_type": "percentage"
    },
    {
      "kpi_id": "phase_e_forecast_confidence",
      "title": "Phase E: Forecast Confidence (CI width ratio)",
      "description": "Prediction interval width relative to point estimate. Tighter CI = higher confidence in forecast.",
      "phase": "E",
      "unit": "0-1 (CI width ratio)",
      "benchmark": 0.25,
      "risk_threshold": 0.5,
      "features": [
        "Mean confidence by borough",
        "Median CI width and quartile ranges",
        "Min/max confidence extremes",
        "Standard deviation (confidence variability)",
        "Simpson's Diversity of confidence levels",
        "Bootstrap CI coverage metrics",
        "Cross-borough confidence comparison",
        "Forecast reliability indicators",
        "Data quality assessment"
      ],
      "tags": ["phase-e", "forecast", "confidence", "bootstrap", "kpi"],
      "metric_type": "confidence"
    },
    {
      "kpi_id": "phase_f_sla_probability",
      "title": "Phase F: SLA Breach Probability (%)",
      "description": "Bootstrap-derived probability of missing 14-day SLA target. Critical risk metric for service level compliance.",
      "phase": "F",
      "unit": "% (breach probability)",
      "benchmark": 10,
      "risk_threshold": 25,
      "features": [
        "Mean breach probability by borough",
        "Median probability and quartile ranges",
        "Min/max breach risk extremes",
        "Standard deviation (probability variability)",
        "Simpson's Diversity of risk profiles",
        "Bootstrap 95% confidence intervals",
        "Cross-borough SLA status matrix",
        "Time-to-SLA countdown by borough",
        "Risk escalation alerts"
      ],
      "tags": ["phase-f", "sla", "compliance", "risk", "bootstrap", "kpi"],
      "metric_type": "probability"
    },
    {
      "kpi_id": "phase_f_risk_score",
      "title": "Phase F: Operational Risk Score (0-100)",
      "description": "Composite risk index combining violations, trends, SLA probability, and resource gaps. Holistic operational risk assessment.",
      "phase": "F",
      "unit": "0-100 (risk score)",
      "benchmark": 40,
      "risk_threshold": 70,
      "features": [
        "Mean risk score by borough",
        "Median risk and quartile distribution",
        "Risk score extremes (min/max)",
        "Standard deviation (risk variability)",
        "Simpson's Diversity of risk factors",
        "Risk component breakdown table",
        "Cross-borough risk heatmap",
        "Risk trend (improving/deteriorating)",
        "Mitigation roadmap by borough"
      ],
      "tags": ["phase-f", "risk", "composite", "operational", "kpi"],
      "metric_type": "risk"
    },
    {
      "kpi_id": "phase_f_ci_coverage",
      "title": "Phase F: 95% CI Coverage (width ratio)",
      "description": "Bootstrap confidence interval width as percentage of point estimate. Measures forecast uncertainty bounds.",
      "phase": "F",
      "unit": "% (CI width ratio)",
      "benchmark": 15,
      "risk_threshold": 35,
      "features": [
        "Mean CI coverage by borough",
        "Median CI width and quartile ranges",
        "Min/max coverage extremes",
        "Standard deviation (coverage variability)",
        "Simpson's Diversity of confidence bounds",
        "CI lower/upper bounds by borough",
        "Cross-borough coverage comparison",
        "Data quality implications",
        "Recommendations for reducing bounds"
      ],
      "tags": ["phase-f", "confidence", "bootstrap", "intervals", "kpi"],
      "metric_type": "percentage"
    },
    {
      "kpi_id": "phase_f_investment_justification",
      "title": "Phase F: Investment ROI Score (violations/$1K)",
      "description": "Expected reduction in violations per $1,000 invested. Bootstrap-derived ROI for budget allocation decisions.",
      "phase": "F",
      "unit": "violations/$1K invested",
      "benchmark": 5,
      "risk_threshold": 2,
      "features": [
        "Mean ROI by borough",
        "Median ROI and quartile ranges",
        "Min/max ROI extremes",
        "Standard deviation (ROI variability)",
        "Simpson's Diversity of ROI profiles",
        "Bootstrap confidence intervals on ROI",
        "Cross-borough ROI comparison matrix",
        "Cost-benefit analysis by scope",
        "Budget allocation recommendations",
        "Payback period projections"
      ],
      "tags": ["phase-f", "roi", "investment", "budget", "bootstrap", "kpi"],
      "metric_type": "roi"
    }
  ],
  "shared_schema": {
    "database": "md:app_queries",
    "views": ["v_kpi_dashboard"],
    "source_table": "analytics.kpi_metrics",
    "borough_dimension": ["MN", "BX", "BK", "QN", "SI"],
    "statistics_computed": [
      "mean",
      "median",
      "min",
      "max",
      "q1_quartile",
      "q3_quartile",
      "iqr",
      "stddev",
      "simpsons_diversity_index",
      "crosstabs_by_borough"
    ]
  },
  "deployment_notes": "Each Dive includes: (1) time-series trend visualization, (2) borough-level statistics panel (mean/median/quartiles/IQR/SD/n), (3) Simpson's Diversity Index for distribution evenness, (4) cross-tab comparison matrix, (5) risk status indicators, (6) interactive borough selection, (7) detailed metadata footer. All Dives use consistent theme (Corporate Dashboard style) with benchmark and risk threshold reference lines."
}
