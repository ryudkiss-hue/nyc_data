    "classification_logic": [
      "1. Infer category from complaint description keywords",
      "2. Infer urgency from keywords, category baseline, and location precision",
      "3. Determine response status: RESOLVED | PENDING | DELAYED | ABANDONED",
      "   - RESOLVED: complaint closed",
      "   - PENDING: days_open < SLA",
      "   - DELAYED: days_open > SLA but < SLA*1.5",
      "   - ABANDONED: days_open > SLA*1.5",
      "4. Assess time adequacy vs SLA target",
      "5. Compute dimension scores and overall satisfaction",
      "6. Identify flagged issues (missing location, reopens, duplicates, delays)",
      "7. Recommend next action (ESCALATE, PRIORITIZE, DISPATCH, MONITOR, CONTINUE)"
    ]
  },
