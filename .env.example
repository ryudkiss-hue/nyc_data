# NYC Open Data (Socrata) Configuration
# Required: Get from https://data.cityofnewyork.us/account/login
SOCRATA_APP_TOKEN=your-socrata-app-token-here
SOCRATA_DOMAIN=data.cityofnewyork.us

# Claude API Configuration (required for NL-to-SOQL translation)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: LLM Configuration
GEMINI_API_KEY=your-gemini-api-key-here
OLLAMA_HOST=http://localhost:11434

# Optional: Operational Features
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PG_DSN=postgresql://user:password@host:5432/database

# Optional: Database & Cache
DUCKDB_PATH=data/local_db/nyc_mission_control.duckdb
SOCRATA_CACHE_DIR=data/cache

# Python Configuration
PYTHONPATH=src:.
PYTHON_VERSION=3.11.9
