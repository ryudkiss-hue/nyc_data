# NYC Sidewalk Data Toolkit - Environment Configuration Template
# Copy to .env and fill in actual values

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/nyc_data

# MongoDB connection string (optional)
MONGO_URI=mongodb://localhost:27017/nyc_data

# ============================================================================
# API Configuration
# ============================================================================

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# API base URL (for frontend)
API_URL=http://localhost:8000
API_BASE_PATH=/api/v1

# ============================================================================
# Frontend Configuration
# ============================================================================

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Frontend API endpoint
VITE_API_URL=http://localhost:8000/api/v1/llm

# ============================================================================
# LLM Configuration
# ============================================================================

# LLM Provider: ollama, openai, huggingface
LLM_PROVIDER=ollama

# Model name
LLM_MODEL=mistral

# LLM API keys (if using cloud providers)
# OPENAI_API_KEY=sk-...
# HUGGINGFACE_API_TOKEN=hf_...
# GEMINI_API_KEY=

# Ollama endpoint (if using Ollama)
OLLAMA_HOST=http://localhost:11434

# ============================================================================
# Socrata API Configuration
# ============================================================================

# Socrata domain (NYC data portal)
SOCRATA_DOMAIN=data.cityofnewyork.us

# Socrata API credentials (for higher rate limits)
SOCRATA_APP_TOKEN=
SOCRATA_APP_SECRET=

# ============================================================================
# Security Configuration
# ============================================================================

# Secret key for JWT tokens
SECRET_KEY=your-secret-key-change-in-production

# Algorithm for JWT tokens
JWT_ALGORITHM=HS256

# JWT expiration time (hours)
JWT_EXPIRATION=24

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, standard
LOG_FORMAT=standard

# Log file path (optional)
LOG_FILE=logs/app.log

# ============================================================================
# Development Configuration
# ============================================================================

# Debug mode (disable in production)
DEBUG=true

# Reload on code changes
RELOAD=true

# Enable profiling
ENABLE_PROFILING=false

# ============================================================================
# Production Configuration
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# New Relic API key (optional)
NEW_RELIC_API_KEY=

# ============================================================================
# Data Quality Configuration
# ============================================================================

# Data quality check interval (minutes)
QUALITY_CHECK_INTERVAL=60

# SLA freshness threshold (hours)
SLA_FRESHNESS_HOURS=24

# Quality score threshold (0-100)
QUALITY_THRESHOLD=80

# ============================================================================
# Airflow Configuration (optional)
# ============================================================================

# Airflow base log folder
AIRFLOW_HOME=./airflow

# Airflow broker URL (Celery)
AIRFLOW__CELERY__BROKER_URL=redis://localhost:6379/0

# Airflow result backend
AIRFLOW__CELERY__RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# Email Configuration (for alerts)
# ============================================================================

# SMTP server
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=username
SMTP_PASSWORD=password

# Email from address
EMAIL_FROM=noreply@example.com

# Alert recipients (comma-separated)
ALERT_RECIPIENTS=admin@example.com

# Teams/Slack Webhook URL for nightly sync alerts
# WEBHOOK_URL=

# ============================================================================
# Microsoft 365 Integration (SharePoint & Outlook)
# ============================================================================

# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=

# ============================================================================
# AWS Configuration (if deploying to AWS)
# ============================================================================

# AWS region
AWS_REGION=us-east-1

# AWS access key (use IAM roles in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# S3 bucket for backups
# S3_BACKUP_BUCKET=nyc-data-backups

# ============================================================================
# Azure Configuration (if deploying to Azure)
# ============================================================================

# Azure subscription ID
# AZURE_SUBSCRIPTION_ID=

# Azure resource group
# AZURE_RESOURCE_GROUP=nyc-data

# Azure storage account name
# AZURE_STORAGE_ACCOUNT=

# ============================================================================
# GCP Configuration (if deploying to GCP)
# ============================================================================

# GCP project ID
# GCP_PROJECT_ID=

# GCP credentials file path
# GOOGLE_APPLICATION_CREDENTIALS=

# GCP bucket for backups
# GCS_BACKUP_BUCKET=nyc-data-backups

# ============================================================================
# Docker Configuration
# ============================================================================

# Docker image registry
DOCKER_REGISTRY=ghcr.io

# Docker image tag
DOCKER_IMAGE_TAG=latest

# ============================================================================
# Feature Flags
# ============================================================================

# Enable LLM features
ENABLE_LLM=true

# Enable geospatial features
ENABLE_GEOSPATIAL=true

# Enable data quality checks
ENABLE_QUALITY_CHECKS=true

# Enable change data capture
ENABLE_CDC=true

# Enable lineage tracking
ENABLE_LINEAGE=true

# Enable observability
ENABLE_OBSERVABILITY=true
