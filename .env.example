# Socrata/NYC Open Data Configuration
# Get a free API token from: https://data.cityofnewyork.us/profile/developer_settings
SOCRATA_APP_TOKEN=your-socrata-app-token-here
SOCRATA_DOMAIN=data.cityofnewyork.us

# LLM Configuration
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Local Services
OLLAMA_HOST=http://localhost:11434

# Python Configuration
PYTHONPATH=src:.
PYTHON_VERSION=3.11.9

# Optional: Cache and Storage
SOCRATA_CACHE_DIR=/tmp/socrata_cache
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
