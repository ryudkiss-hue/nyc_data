# NYC DOT SIM Fuzzy Router Configuration
# Copy this file to .env and adjust values for your environment

# Data Sources
ROUTER_REGISTRY_PATH=config/kpi_registry_full.json
ROUTER_QUESTIONS_PATH=config/research_questions.json
ROUTER_EMBEDDINGS_CACHE_PATH=cache/kpi_embeddings.json

# Database
ROUTER_OBSERVABILITY_DB=data/local_db/router_observability.duckdb

# Claude API (for Tier 2 expansion)
ANTHROPIC_API_KEY=sk-...

# Socrata API (for live data fetches)
SOCRATA_APP_TOKEN=your-token-here
SOCRATA_DOMAIN=data.cityofnewyork.us

# Development
ROUTER_DEBUG=false
LOG_LEVEL=INFO

# Optional: Custom paths for production
# ROUTER_REGISTRY_PATH=/opt/socrata-toolkit/registry.json
# ROUTER_OBSERVABILITY_DB=/var/lib/socrata-toolkit/router.duckdb
