  "unified_ingestion_rules": {
    "rule_1": "All 57 datasets treated as single coherent ingestion unit - no artificial split",
    "rule_2": "Tier-based parallelization: critical datasets load first, supplemental last",
    "rule_3": "Smart batching: tier_0 (5 per batch), tier_1 (8 per batch), tier_2 (12 per batch), tier_3 (20 per batch)",
    "rule_4": "Cache policy per dataset: prefetch_full (tier_0), prefetch_incremental (tier_1), lazy_load (tier_2-3)",
    "rule_5": "Empty/broken datasets (capital_blocks, permit_stipulations) flagged but not blocking",
    "rule_6": "SLA enforcement: HIGH datasets must refresh within 14 days, MEDIUM within 30 days, LOW within 60 days",
    "rule_7": "All datasets land in 'raw' schema, staged to 'staging', analytics in domain-specific schemas",
    "rule_8": "Unified checkpoint & lineage tracking across all 57 datasets",
    "rule_9": "No 'cached vs Socrata' distinction - all use same ingestion, caching, and materialization pipeline",
    "rule_10": "Metadata completeness required: fourfour, row_count, primary_key, domain_schema for every dataset"
  }
}
