      "real_time_1h": 3,
      "daily_24h": 8,
      "weekly_7d": 15,
      "monthly_30d": 18,
      "quarterly_90d": 7
    },
    "lineage_sample": "Every Metric traces back to 1-3 source datasets from the 57 unified datasets. Calculation rules, quality gates, and refresh schedule documented."
  },

  "schema_layers": {
    "raw_schema": {
      "purpose": "Unmodified source data",
      "tables": 57,
      "retention": "indefinite",
      "quality_gates": [
        "row_count matches source",
        "PK uniqueness 100%",
        "audit columns present (source_timestamp, load_timestamp, record_hash)"
      ]
    },
    "staging_schema": {
      "purpose": "Cleaned, deduplicated, type-cast",
      "tables": 57,
      "retention": "indefinite",
      "quality_gates": [
        "PK uniqueness 100%",
        "row_count 95-110% of raw",
        "no nulls in required fields"
      ]
    },
    "analytics_domain_schemas": {
      "sim_core": "8 tables, inspection/violation/service analytics",
      "accessibility": "6 tables, ramp program and ADA compliance",
      "coordination": "8 tables, permits, construction, regulatory",
      "overlays": "9 tables, spatial enrichment and reference",
      "extended": "11 tables, budget, scheduling, planning",
      "retention": "indefinite"
    }
  },

  "dive_categories": {
    "exploratory": "Ad-hoc analysis, personal exploration",
    "operational": "Regular monitoring dashboards",
    "analytical": "Deep investigation for reporting",
    "strategic": "Executive briefing and decision support"
  },

  "governance_rules": {
    "retention": "indefinite_all_data",
    "access_control": "none_solo_user",
    "audit_logging": "personal_reproducibility_tracking",
    "quality_gates": "automated_data_validation",
    "archival": "keep_everything_forever"
  }
