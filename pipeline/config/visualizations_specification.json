{
  "visualizations_framework": {
    "version": "2.0",
    "created_at": "2026-06-18",
    "description": "Plotly/Dash Visualization Specification for NYC DOT Mission Control",
    "framework": "Plotly Express + Dash + Mantine UI",
    "total_dashboards": 7,
    "total_charts": 45,
    "backend": "FastAPI + DuckDB",
    "styling": "Mantine component library with custom CSS"
  },

  "dashboard_layouts": [
    {
      "id": "dashboard_001",
      "name": "Mission Control Home",
      "title": "NYC DOT Mission Control",
      "description": "Central operational command center with real-time Metrics and alerts",
      "route": "/",
      "icon": "home",
      "access_level": "internal",
      "refresh_interval_seconds": 300,
      "layout": {
        "rows": 3,
        "columns": 3,
        "components": [
          {
            "type": "metric_scorecard",
            "position": "top_left",
            "title": "Inspection Completion Rate",
            "metric": "violation_closure_rate",
            "metric_type": "percentage",
            "target": 85,
            "current_value": "{{metric_value}}",
            "trend": "up",
            "sparkline": true
          },
          {
            "type": "metric_scorecard",
            "position": "top_center",
            "title": "Ramp Installation Progress",
            "metric": "ramp_completion_rate",
            "metric_type": "percentage",
            "target": 80,
            "current_value": "{{metric_value}}",
            "trend": "up"
          },
          {
            "type": "metric_scorecard",
            "position": "top_right",
            "title": "Budget Compliance",
            "metric": "budget_variance",
            "metric_type": "percentage",
            "target": 0,
            "current_value": "{{metric_value}}",
            "trend": "neutral"
          },
          {
            "type": "chart",
            "position": "middle_left",
            "title": "Violation Closure by Borough",
            "chart_type": "bar",
            "data_source": "sim_core.violation_timeline",
            "x_axis": "borough",
            "y_axis": "closure_rate",
            "groupby": ["violation_type"],
            "height": "medium"
          },
          {
            "type": "chart",
            "position": "middle_center",
            "title": "Ramp Completion Trend",
            "chart_type": "line",
            "data_source": "accessibility.ramp_completion_status",
            "x_axis": "month",
            "y_axis": ["completion_rate", "installation_pace"],
            "legend": "right",
            "height": "medium"
          },
          {
            "type": "chart",
            "position": "middle_right",
            "title": "SLA Compliance Scorecard",
            "chart_type": "gauge",
            "data_source": "serving.metric_borough_results",
            "metric_id": "METRIC-009",
            "min": 0,
            "max": 100,
            "target": 95,
            "height": "medium"
          },
          {
            "type": "chart",
            "position": "bottom_left",
            "title": "Active Permits by Status",
            "chart_type": "funnel",
            "data_source": "coordination.permit_lifecycle",
            "stages": ["issued", "approved", "active", "completed"],
            "height": "medium"
          },
          {
            "type": "chart",
            "position": "bottom_center",
            "title": "Data Quality Score",
            "chart_type": "radial",
            "data_source": "serving.quality_scorecards",
            "dimensions": ["completeness", "validity", "consistency", "freshness"],
            "height": "medium"
          },
          {
            "type": "alerts",
            "position": "bottom_right",
            "title": "System Alerts",
            "alert_sources": ["sla_breaches", "quality_gates", "governance_violations"],
            "height": "medium"
          }
        ]
      }
    },
    {
