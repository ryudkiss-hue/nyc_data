  "chart_specifications": {
    "chart_types": {
      "bar": {
        "library": "plotly.express.bar",
        "use_cases": ["comparing categories", "showing distributions", "budget variance"],
        "interactivity": ["hover_details", "click_drill_down", "legend_toggle"],
        "components": {
          "visual": ["bars", "axis_labels", "title", "legend", "gridlines"],
          "statistics": ["count", "mean", "std_dev", "min", "max"],
          "summary_stats": ["n", "mean", "median", "mode", "std", "var", "skew", "kurtosis"],
          "annotations": ["value_labels", "trend_line", "target_line", "reference_line"]
        }
      },
      "line": {
        "library": "plotly.express.line",
        "use_cases": ["time series", "trends", "monitoring"],
        "interactivity": ["range_slider", "hover_details", "legend_toggle"],
        "components": {
          "visual": ["line_trace", "markers", "axis_labels", "title", "legend", "gridlines"],
          "statistics": ["trend_direction", "slope", "r_squared", "confidence_interval"],
          "summary_stats": ["min", "max", "mean", "median", "trend_acceleration"],
          "annotations": ["best_fit_line", "confidence_band", "forecast_line", "target_line"]
        }
      },
      "histogram": {
        "library": "plotly.express.histogram",
        "use_cases": ["distributions", "frequency analysis", "outlier detection"],
        "interactivity": ["bin_adjustment", "hover_details", "legend_toggle"],
        "components": {
          "visual": ["bars", "axis_labels", "title", "legend", "gridlines"],
          "statistics": ["mean_line", "median_line", "std_dev_bands", "min", "max"],
          "summary_stats": ["n", "mean", "median", "mode", "std", "var", "skew", "kurtosis"],
          "annotations": ["four_moments", "percentile_lines", "outlier_threshold"]
        }
      },
      "box": {
        "library": "plotly.express.box",
        "use_cases": ["quartile analysis", "outlier detection", "distribution comparison"],
        "interactivity": ["hover_details", "legend_toggle", "click_group"],
        "components": {
          "visual": ["box", "whiskers", "median_line", "outliers", "axis_labels", "title"],
          "statistics": ["q1", "median", "q3", "iqr", "min", "max", "outlier_threshold"],
          "summary_stats": ["four_moments", "percentiles_25_50_75", "whisker_calculation", "outlier_count"],
          "annotations": ["mean_marker", "outlier_points", "legend_with_counts"]
        }
      },
      "scatter": {
        "library": "plotly.express.scatter",
        "use_cases": ["correlation analysis", "trend identification", "outlier detection"],
        "interactivity": ["hover_details", "click_points", "legend_toggle"],
        "components": {
          "visual": ["points", "axis_labels", "title", "legend", "gridlines"],
          "statistics": ["correlation_coefficient", "r_squared", "slope", "intercept"],
          "summary_stats": ["pearson_r", "p_value", "confidence_interval", "regression_line"],
          "annotations": ["best_fit_line", "confidence_band", "outlier_highlighting", "quadrant_lines"]
        }
      },
      "heatmap": {
        "library": "plotly.express.imshow",
        "use_cases": ["correlations", "performance grid", "quality matrix"],
        "interactivity": ["hover_values", "color_scale_toggle"],
        "components": {
          "visual": ["cells", "color_scale", "axis_labels", "title", "colorbar"],
          "statistics": ["correlation_values", "min", "max", "mean"],
          "summary_stats": ["descriptive_stats_per_cell"],
          "annotations": ["value_labels", "significant_threshold_highlighting"]
        }
      },
      "funnel": {
        "library": "plotly.express.funnel",
        "use_cases": ["process stages", "permit lifecycle", "conversion"],
        "interactivity": ["hover_details", "stage_analysis"],
        "components": {
          "visual": ["funnel_segments", "axis_labels", "title", "legend"],
          "statistics": ["count_per_stage", "drop_rate", "conversion_rate"],
          "summary_stats": ["stage_counts", "percentage_remaining", "drop_off_points"],
          "annotations": ["percentage_labels", "drop_rate_callouts"]
        }
      },
      "pie": {
        "library": "plotly.express.pie",
        "use_cases": ["composition", "budget allocation", "market share"],
        "interactivity": ["click_drill_down", "hover_percentage"],
        "components": {
          "visual": ["slices", "labels", "title", "legend"],
          "statistics": ["percentage", "count", "cumulative_percentage"],
          "summary_stats": ["total_count", "top_n_segments", "other_category_summary"],
          "annotations": ["percentage_labels", "value_labels", "cumulative_line"]
        }
      },
      "gauge": {
        "library": "plotly.graph_objects.Indicator",
        "use_cases": ["Metric cards", "progress tracking", "compliance monitoring"],
        "interactivity": ["hover_tooltip"],
        "components": {
          "visual": ["gauge_arc", "needle", "axis_labels", "title", "reference_lines"],
          "statistics": ["current_value", "target_value", "delta_value"],
          "summary_stats": ["percentage_of_target", "trend_direction", "variance"],
          "annotations": ["target_line", "threshold_zones", "trend_arrow"]
        }
      },
      "sunburst": {
        "library": "plotly.express.sunburst",
        "use_cases": ["hierarchical composition", "resource allocation", "drill-down analysis"],
        "interactivity": ["click_drill_down", "hover_details"],
        "components": {
          "visual": ["nested_arcs", "labels", "color_scale", "title"],
          "statistics": ["value_per_segment", "percentage_of_parent"],
          "summary_stats": ["hierarchy_depth", "total_value", "segment_distribution"],
          "annotations": ["percentage_labels", "value_labels"]
        }
      },
      "gis_scatter": {
        "library": "plotly.express.scatter_mapbox",
        "use_cases": ["location data", "asset mapping", "spatial analysis"],
        "interactivity": ["hover_details", "zoom_pan", "click_popup"],
        "components": {
          "visual": ["points", "basemap", "color_scale", "size_legend", "title"],
          "statistics": ["point_density", "spatial_distribution", "clustering_metrics"],
          "summary_stats": ["point_count_by_category", "spatial_autocorrelation"],
          "annotations": ["cluster_circles", "heatmap_overlay", "legend_with_counts"]
        }
      },
      "gis_polygon": {
        "library": "plotly.graph_objects.Choropleth",
        "use_cases": ["geographic areas", "conflict zones", "permit areas"],
        "interactivity": ["hover_details", "zoom_pan", "color_scale"],
        "components": {
          "visual": ["polygons", "color_scale", "basemap", "title", "colorbar"],
          "statistics": ["value_per_polygon", "min", "max", "mean", "std_dev"],
          "summary_stats": ["descriptive_stats_per_region", "quartile_distribution"],
          "annotations": ["legend_with_scale", "significant_area_highlighting"]
        }
      },
      "violin": {
        "library": "plotly.express.violin",
        "use_cases": ["distribution shape comparison", "density analysis", "outlier detection"],
        "interactivity": ["hover_details", "legend_toggle"],
        "components": {
          "visual": ["violin_shape", "box_inside", "points", "axis_labels", "title"],
          "statistics": ["density_curve", "quartiles", "mean", "median"],
          "summary_stats": ["four_moments", "kurtosis", "skewness", "distribution_shape"],
          "annotations": ["mean_marker", "median_line", "percentile_bands"]
        }
      }
    }
  },

  "dashboard_integration": {
    "backend": "FastAPI endpoint: /api/dashboard/{dashboard_id}",
    "data_source": "DuckDB serving schema (analytics views + Metric materialization)",
    "refresh_mechanism": "Callback-based auto-refresh via Dash clientside callbacks",
    "styling": "Mantine UI components + custom CSS from app/assets/",
    "authentication": "Required (internal DOT staff only)",
    "audit_logging": "All dashboard views logged via governance audit trail"
  },

  "performance_requirements": {
    "page_load_time_seconds": 3,
    "chart_render_time_seconds": 2,
