{
  "name": "manhattan-mission-control",
  "productName": "Manhattan Mission Control",
  "version": "3.0.0",
  "description": "NYC DOT Open Data Explorer & Agency Analytics — native desktop app",
  "author": "Richard Yudkiss",
  "license": "MIT",
  "main": "main.js",
  "homepage": "https://github.com/ryudkiss-hue/nyc_data",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryudkiss-hue/nyc_data.git"
  },
  "scripts": {
    "prestart": "node scripts/copy-spa.js",
    "start": "electron .",
    "predist": "node scripts/copy-spa.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1"
  },
  "build": {
    "appId": "gov.nyc.dot.missioncontrol",
    "productName": "Manhattan Mission Control",
    "copyright": "Copyright © 2026 Richard Yudkiss",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "vendor/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../config",
        "to": "config"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Manhattan Mission Control"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ryudkiss-hue",
        "repo": "nyc_data"
      }
    ]
  }
}
