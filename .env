# NYC DOT Sidewalk Inspection & Management Toolkit
# Environment Configuration - Consolidate all settings here
# Last updated: 2026-06-17

# ============================================================================
# REQUIRED: NYC Open Data (Socrata API)
# ============================================================================
# Register at: https://data.cityofnewyork.us/profile/developer_settings
# Token enables higher rate limits (>2K rows) and API access
SOCRATA_APP_TOKEN=TfrAwqroXIrKRPwPvWpEZnkcT
SOCRATA_DOMAIN=data.cityofnewyork.us

# ============================================================================
# REQUIRED:
# ============================================================================
# Used for NL-to-SOQL translation and advanced analytics
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MotherDuck (cloud DuckDB analytics)
# Get from: https://console.motherduck.com/
MOTHERDUCK_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..JU5jDKSDToYaDJSKagTSpzz1Dn-KB7Ix3BXkILa4evY

# Google Cloud (GCS + BigQuery)
# Requires: gcloud auth login && gcloud auth application-default login
GCP_PROJECT=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name

# ============================================================================
# OPTIONAL: Alternative LLMs & Services
# ============================================================================

# Gemini (Google)
GEMINI_API_KEY=

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434

# Slack notifications (optional)
SLACK_WEBHOOK_URL=

# ============================================================================
# DATABASE & PERSISTENCE
# ============================================================================

# Local DuckDB (L2 cache for NYC data)
DUCKDB_PATH=./data/local_db/nyc_mission_control.duckdb

# PostgreSQL (optional, for data warehouse / conflict detection)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://dot_user:dot_pass@localhost:5432/sidewalk_db
PG_DSN=postgresql://postgres:Gessie6854!@localhost:5432/nyc_data

# ============================================================================
# CACHING & STORAGE
# ============================================================================

# Parquet cache directory (local copy of fetched data)
SOCRATA_CACHE_DIR=data/cache

# Output directory for reports, exports, generated files
OUTPUT_DIR=./outputs
DATA_DIR=./data

# ============================================================================
# PYTHON CONFIGURATION
# ============================================================================

# Python path for imports
PYTHONPATH=src:.

# Python version (informational, for Docker builds)
PYTHON_VERSION=3.11.9

# ============================================================================
# ANALYST CONFIGURATION (optional, for scheduled workflows)
# ============================================================================

# Analyst profile YAML (for analyst-specific workflows)
ANALYST_PROFILE=./config/analyst_profile.yaml

# Cron schedule for scheduled analyst tasks (e.g., daily reports)
# Format: minute hour day month dayofweek
# Example: 0 6 * * 1 (6 AM every Monday)
ANALYST_CRON=0 6 * * 1

# ============================================================================
# DOCKER COMPOSE (optional, for postgres service)
# ============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=Gessie6854!
POSTGRES_DB=sidewalk_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================================
# WIZARD / SETUP (optional, for non-interactive installations)
# ============================================================================

# Set to 1 for non-interactive setup
WIZARD_NONINTERACTIVE=

# Allow empty token in wizard (for demo/testing)
WIZARD_ALLOW_EMPTY_TOKEN=

# ============================================================================
# NOTES
# ============================================================================
#
# This file consolidates all environment variables for the project.
#
# Required fields (must be set):
#   - SOCRATA_APP_TOKEN (for live data)
#   - ANTHROPIC_API_KEY (for NL-to-SOQL, analysis)
#
# Optional fields (set only if needed):
#   - MOTHERDUCK_TOKEN (for cloud analytics via MotherDuck)
#   - GCP_PROJECT, GCS_BUCKET (for Google Cloud sync)
#   - PG_DSN (for PostgreSQL data warehouse)
#   - SLACK_WEBHOOK_URL (for notifications)
#   - OLLAMA_HOST, GEMINI_API_KEY (for alternative LLMs)
#
# Security:
#   - Never commit real credentials to git
#   - .env is in .gitignore (not committed)
#   - Keep .env.example as template for new users
#
# Loading:
#   - Python: load_dotenv() from python-dotenv
#   - Docker: env_file: .env in docker-compose.yml
#   - CLI: export $(cat .env | xargs)
#
